# AURA AI — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Optional
AURA_MODE=assistant          # assistant | agent | focus
SCREEN_CAPTURE=true          # Enable live screen vision
WHATSAPP_ENABLED=true        # Enable WhatsApp automation
EMAIL_ENABLED=true           # Enable email automation
DEBUG=false                  # Verbose logging
